// Auth.js (next-auth) Prisma adapter schema.
// Docs: https://authjs.dev/getting-started/adapters/prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  accounts          Account[]
  sessions          Session[]
  playlistLinks     UserPlaylistLink[]
  cachedResponses   CachedSpotifyResponse[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Playlist + PlaylistTrack store Bompton playlist data synced by the
// browser extension. The Spotify dev-API quota no longer returns track-level
// data for invite-collaborator playlists, so we mirror that data locally.
model Playlist {
  id          String    @id
  name        String
  ownerId     String?
  ownerName   String?
  snapshotId  String?
  imageUrl    String?
  totalTracks Int       @default(0)
  lastSyncAt  DateTime?
  lastSyncBy  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tracks PlaylistTrack[]
  links  UserPlaylistLink[]
}

// UserPlaylistLink says "this user has imported this playlist onto their
// dashboard." The underlying Playlist + PlaylistTrack data is shared (deduped
// by playlist id), so two users who import the same playlist share storage.
// The link is what scopes which playlists appear on whose dashboard.
model UserPlaylistLink {
  id         String   @id @default(cuid())
  userId     String
  playlistId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@unique([userId, playlistId])
  @@index([userId])
  @@index([playlistId])
}

model PlaylistTrack {
  id               String   @id @default(cuid())
  playlistId       String
  position         Int
  trackSpotifyId   String?
  trackName        String
  trackUri         String
  trackDurationMs  Int
  trackExplicit    Boolean  @default(false)
  trackPreviewUrl  String?
  albumName        String
  albumImageUrl    String?
  artistsJson      Json
  addedAt          DateTime
  addedBySpotifyId String?
  isLocal          Boolean  @default(false)

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@unique([playlistId, position])
  @@index([playlistId])
  @@index([addedBySpotifyId])
}

// Durable Spotify response cache. Populated whenever the dashboard's
// /api/dashboard/[kind] route fetches fresh data from Spotify; read
// on subsequent requests until expiresAt. Lets us honor long TTLs
// (24h for profile / devices / saved content / followed artists)
// across serverless cold starts, so a user pinging the dashboard
// multiple times a day only hits Spotify once for those slow-
// changing endpoints. Shorter TTLs for things that actually change
// often (playlists, top items) stay in a lightweight in-memory
// cache layered on top.
model CachedSpotifyResponse {
  id        String   @id @default(cuid())
  userId    String
  kind      String
  data      Json
  expiresAt DateTime
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, kind])
  @@index([userId])
  @@index([expiresAt])
}
