# Spotify app credentials — create at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Auth.js — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
# Local dev; in prod set to your Vercel URL (e.g. https://bompton-spotify.vercel.app)
NEXTAUTH_URL=http://localhost:3000

# Neon Postgres connection string
DATABASE_URL=

# Comma-separated list of Spotify account emails allowed to sign in
ALLOWED_EMAILS=you@example.com,friend@example.com
